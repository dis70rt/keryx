# ──────────────────────────────────────────────────
# Keryx Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:e2b
LLM_TEMPERATURE=0.7
OLLAMA_BASE_URL=http://localhost:11434

# ── Google Sheets ─────────────────────────────────
ADMIN_EMAIL=your.actual.email@gmail.com
GOOGLE_SHEETS_CRED_PATH=data/google_credentials.json
TARGET_SHEET_NAME=Keryx Outreach
SHEET_TAB_TARGETS=Targets
SHEET_TAB_NOTES=Connection Notes
SHEET_TAB_DMS=DM Messages

# ── Context Files ─────────────────────────────────
RESUME_PATH=data/resume.tex
PROJECTS_PATH=data/projects.json

# ── Scraper ───────────────────────────────────────
SENDER_LINKEDIN_URL=https://www.linkedin.com/in/in-saikat/
AUTH_STATE_PATH=data/auth_state.json
HEADLESS=false

# ── State Cache ───────────────────────────────────
CACHE_DB_PATH=data/cache.db